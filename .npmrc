# Font Awesome Pro Kit registry. The auth token is NOT stored here — it is read
# from the FONTAWESOME_PACKAGE_TOKEN environment variable (local shell, GitHub
# Actions secret, and Vercel project env). Never commit the token.
@awesome.me:registry=https://npm.fontawesome.com/
@fortawesome:registry=https://npm.fontawesome.com/
//npm.fontawesome.com/:_authToken=${FONTAWESOME_PACKAGE_TOKEN}
