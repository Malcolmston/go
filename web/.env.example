# Frontend build-time env for the go aggregator web app (Vite).
# Copy to `.env.local` for local development. Only VITE_-prefixed vars are
# exposed to the browser bundle.

# Base URL for the search + package-graph API (serverless functions).
# Leave BLANK to call the same origin — this is correct on Vercel, where the
# functions under /api are deployed alongside this static site.
# Set this only to point the frontend at a different host (e.g. a preview
# deployment or a separately-hosted API): VITE_API_URL=https://my-api.example.com
VITE_API_URL=

# NOTE: Elasticsearch is NOT configured here. It is enabled server-side by
# setting ELASTICSEARCH_URL and ELASTICSEARCH_API_KEY in the Vercel project
# environment variables (Project Settings -> Environment Variables). When those
# are unset the search function transparently falls back to an in-memory BM25
# ranker, and the frontend falls back to the bundled data files on hosts without
# serverless functions (e.g. GitHub Pages). Do not put ES secrets in this file.
