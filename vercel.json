{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install && cd web && npm ci",
  "buildCommand": "npm run build:graph && cd web && npm run build",
  "outputDirectory": "web/dist",
  "cleanUrls": true,
  "functions": {
    "api/*.js": { "maxDuration": 10, "includeFiles": "api/_data/**" }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
